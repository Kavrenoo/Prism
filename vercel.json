{
  "version": 2,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    },
    {
      "source": "/(.*\\.lua)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/key", "destination": "/key.html" },
    { "source": "/api/prism/:path*", "destination": "/api/prism.js" },
    { "source": "/api/nametags/:path*", "destination": "/api/prism.js" },
    { "source": "/api/servers/:path*", "destination": "/api/prism.js" }
  ]
}
